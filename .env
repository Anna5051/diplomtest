DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=charitor_ai_db
DB_PORT=3306
PORT=3001

# Встроенная для пользователей: ollama (бесплатно на сервере) | cloud (Chutes из .env)
BUILTIN_LLM_MODE=ollama
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_FALLBACK_MODEL=qwen2.5:1.5b

# Облачный LLM (для BUILTIN_LLM_MODE=cloud или своих прокси в чате). Ключ: LLM_API_KEY...

# Chutes (https://chutes.ai) — OpenAI-совместимый API, ключ cpk_...
LLM_PROXY_URL=https://llm.chutes.ai/v1/chat/completions
LLM_MODEL=Qwen/Qwen3-32B-TEE
LLM_API_KEY=cpk_afa7b33e443f4d9dacb96b4be95327e1.3cb66e1ff0f557378195138612a290fa.xlze5tJ9hfEtcfZUeAHRwvINUmcDdepw

# OpenRouter:
# LLM_PROXY_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_MODEL=google/gemma-2-9b-it:free

# DeepSeek:
# LLM_PROXY_URL=https://api.deepseek.com/chat/completions
# LLM_MODEL=deepseek-chat