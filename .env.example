# Скопируй в .env и заполни. Файл .env в git не попадает.

# --- MySQL ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=charitor
DB_PORT=3306

PORT=3000

# Ключ шифрования messages.content (тот же, что в .messages-content.key на ПК).
# На Railway обязательно: MESSAGES_CONTENT_KEY=... в Variables, иначе чат падает.
# MESSAGES_CONTENT_KEY=

# --- Встроенная модель для всех пользователей (бесплатно) ---
# ollama — модель на ЭТОМ сервере (пользователям Ollama на ПК не нужна)
# cloud  — облачный API из LLM_PROXY_URL ниже
BUILTIN_LLM_MODE=ollama

# Ollama только на машине, где крутится node config/server.js:
#   https://ollama.com/download  →  ollama serve  →  ollama pull qwen2.5:3b
# Или: .\scripts\setup-ollama.ps1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_FALLBACK_MODEL=qwen2.5:1.5b

# --- Облачный LLM (если BUILTIN_LLM_MODE=cloud или свой прокси в чате) ---
# Ключ только здесь — пользователи в браузере его не видят.

# Chutes: https://chutes.ai — ключ cpk_... (аккаунт / API keys на chutes.ai)
LLM_PROXY_URL=https://llm.chutes.ai/v1/chat/completions
LLM_MODEL=Qwen/Qwen3-32B-TEE
LLM_API_KEY=

# Список моделей: GET https://llm.chutes.ai/v1/models (с Bearer cpk_...)
# Быстрый роутинг: LLM_MODEL=default:latency

# OpenRouter: https://openrouter.ai/keys
# LLM_PROXY_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_MODEL=google/gemma-2-9b-it:free

# DeepSeek: https://platform.deepseek.com/api_keys
# LLM_PROXY_URL=https://api.deepseek.com/chat/completions
# LLM_MODEL=deepseek-chat

# Groq (в РФ часто Forbidden): https://console.groq.com/keys
# LLM_PROXY_URL=https://api.groq.com/openai/v1/chat/completions
# LLM_MODEL=llama-3.1-8b-instant
# или одна строка в config/secrets/llm-api-key.txt (файл в git не попадает)
# LLM_CUSTOM_PROMPT=дополнительные инструкции для всех ответов (необязательно)

